{
  "name": "SkeleVigil",
  "expo": {
    "name": "SkeleVigil",
    "slug": "skelevigil-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_master.png",
    "scheme": "skelevigilfrontend",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.skelevigil-frontend"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#141416",
        "foregroundImage": "./assets/icon_master.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
